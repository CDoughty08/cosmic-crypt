{
  "name": "cosmic-crypt",
  "version": "2.0.0",
  "description": "utility to reduce boilerplate when encrypting/decrypting text",
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "bin": "./dist/cli/index.mjs",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "test": "vitest run --coverage",
    "build": "tsdown",
    "dev": "concurrently -n tsdown,vitest -c cyan,green \"tsdown --watch\" \"vitest\"",
    "prepublishOnly": "tsdown && pnpm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CDoughty08/cosmic-crypt.git"
  },
  "author": "Cody Doughty",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/CDoughty08/cosmic-crypt/issues"
  },
  "homepage": "https://github.com/CDoughty08/cosmic-crypt#readme",
  "devDependencies": {
    "@types/node": "20.19.43",
    "@vitest/coverage-v8": "4.1.8",
    "concurrently": "3.5.0",
    "tsdown": "0.22.2",
    "typescript": "5.9.3",
    "vitest": "4.1.8"
  },
  "dependencies": {
    "commander": "15.0.0"
  }
}
