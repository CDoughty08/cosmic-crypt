{
  "name": "cosmic-crypt",
  "version": "2.0.0",
  "description": "utility to reduce boilerplate when encrypting/decrypting text",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": "./dist/cli/index.js",
  "scripts": {
    "test": "nyc mocha",
    "build": "tsc -p ./tsconfig.publish.json",
    "lint": "echo 'Linting would require TypeScript ESLint setup - using TypeScript compiler for now'",
    "dev": "concurrently -n tsc,mocha -c cyan,green \"tsc -p ./tsconfig.json --watch\" \"mocha --watch\"",
    "coveralls": "cat ./coverage/lcov.info | ./node_modules/.bin/coveralls",
    "prepublishOnly": "tsc -p tsconfig.publish.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CDoughty08/cosmic-crypt.git"
  },
  "author": "Cody Doughty",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/CDoughty08/cosmic-crypt/issues"
  },
  "homepage": "https://github.com/CDoughty08/cosmic-crypt#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "nyc": {
    "check-coverage": true,
    "lines": 95,
    "statements": 95,
    "functions": 90,
    "branches": 75,
    "include": [
      "src/**/*.ts"
    ],
    "exclude": [
      "src/cosmic-crypt.ts",
      "src/cli/index.ts"
    ],
    "extension": [
      ".ts"
    ],
    "require": [
      "ts-node/register"
    ],
    "reporter": [
      "text-summary",
      "html",
      "lcov"
    ],
    "sourceMap": true,
    "instrument": true,
    "all": true
  },
  "devDependencies": {
    "@types/chai": "^4.3.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "@types/sinon": "^17.0.0",
    "chai": "^5.0.0",
    "concurrently": "^8.0.0",
    "coveralls": "^3.1.0",
    "eslint": "^8.0.0",
    "mocha": "^10.0.0",
    "nyc": "^17.0.0",
    "sinon": "^18.0.0",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "inquirer": "^10.0.0"
  }
}
